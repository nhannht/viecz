<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude auth tokens from cloud backup -->
        <exclude domain="file" path="datastore/auth_prefs.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude auth tokens from device-to-device transfer -->
        <exclude domain="file" path="datastore/auth_prefs.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
