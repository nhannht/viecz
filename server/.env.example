# Server Configuration
PORT=8080
GO_ENV=development
CLIENT_URL=http://localhost:8081

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=viecz
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-use-at-least-32-characters

# SMTP (optional — empty SMTP_HOST = no-op email service)
# For dev with Mailpit: SMTP_HOST=localhost, SMTP_PORT=1025, no user/password
# For production with Stalwart: SMTP_HOST=localhost, SMTP_PORT=587, with auth
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@fishcmus.io.vn

# Cloudflare Turnstile (optional — empty = skip bot validation)
TURNSTILE_SECRET_KEY=

# Rate Limiting (optional — disabled by default)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_API_PER_MIN=30
RATE_LIMIT_READ_PER_MIN=60
RATE_LIMIT_FINANCE_PER_MIN=10

# PayOS Credentials (get from PayOS dashboard - optional for now)
PAYOS_CLIENT_ID=your_client_id_here
PAYOS_API_KEY=your_api_key_here
PAYOS_CHECKSUM_KEY=your_checksum_key_here
