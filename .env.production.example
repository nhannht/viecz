# Database
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=viecz

# Server
CLIENT_URL=https://your-domain.com
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_random_string

# PayOS (optional)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
