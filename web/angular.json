{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "yarn",
    "analytics": false,
    "schematicCollections": [
      "angular-eslint"
    ]
  },
  "newProjectRoot": "projects",
  "projects": {
    "web": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "css"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "css",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/tailwind.css",
              "node_modules/maplibre-gl/dist/maplibre-gl.css"
            ],
            "allowedCommonJsDependencies": [
              "maplibre-gl"
            ],
            "server": "src/main.server.ts",
            "outputMode": "server",
            "ssr": {
              "entry": "src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "8kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "web:build:production"
            },
            "development": {
              "buildTarget": "web:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "proxyConfig": "proxy.conf.json",
            "allowedHosts": [
              "viecz-dev.fishcmus.io.vn"
            ]
          }
        },
        "test": {
          "builder": "@angular/build:unit-test"
        },
        "storybook-metro": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "browserTarget": "web:build:development",
            "configDir": ".storybook-metro",
            "port": 6006,
            "compodoc": false,
            "tsConfig": ".storybook-metro/tsconfig.json",
            "styles": [
              ".storybook-metro/tailwind-metro.css"
            ]
          }
        },
        "build-storybook-metro": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "browserTarget": "web:build:development",
            "configDir": ".storybook-metro",
            "compodoc": false,
            "tsConfig": ".storybook-metro/tsconfig.json",
            "styles": [
              ".storybook-metro/tailwind-metro.css"
            ],
            "outputDir": "storybook-metro-static"
          }
        },
        "storybook-glass": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "browserTarget": "web:build:development",
            "configDir": ".storybook-glass",
            "port": 6007,
            "compodoc": false,
            "tsConfig": ".storybook-glass/tsconfig.json",
            "styles": [
              ".storybook-glass/tailwind-glass.css"
            ]
          }
        },
        "build-storybook-glass": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "browserTarget": "web:build:development",
            "configDir": ".storybook-glass",
            "compodoc": false,
            "tsConfig": ".storybook-glass/tsconfig.json",
            "styles": [
              ".storybook-glass/tailwind-glass.css"
            ],
            "outputDir": "storybook-glass-static"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "src/**/*.ts",
              "src/**/*.html"
            ]
          }
        }
      }
    }
  }
}
