{
  "name": "web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:web": "node dist/web/server/server.mjs",
    "compodoc": "compodoc -p .storybook-metro/tsconfig.json -e json -d .storybook",
    "storybook:metro": "yarn compodoc && ng run web:storybook-metro",
    "storybook:glass": "yarn compodoc && ng run web:storybook-glass",
    "build-storybook:metro": "yarn compodoc && ng run web:build-storybook-metro",
    "build-storybook:glass": "yarn compodoc && ng run web:build-storybook-glass",
    "build-storybook": "yarn compodoc && ng run web:build-storybook-metro && ng run web:build-storybook-glass",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write 'src/**/*.{ts,html,css,scss}'"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.1.0",
    "@angular/platform-server": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@angular/ssr": "^21.1.4",
    "@jsverse/transloco": "^8.2.1",
    "@maplibre/ngx-maplibre-gl": "^21.0.2",
    "@sentry/angular": "^10.40.0",
    "@tailwindcss/postcss": "^4.2.0",
    "angular-three": "4.0.9",
    "angular-three-soba": "4.0.9",
    "express": "^5.1.0",
    "firebase": "^12.9.0",
    "google-libphonenumber": "^3.2.44",
    "http-proxy-middleware": "^3.0.5",
    "lil-gui": "^0.21.0",
    "maplibre-gl": "^5.19.0",
    "ngxtension": "7.2.0",
    "postcss": "^8.5.6",
    "postprocessing": "^6.38.3",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.0",
    "three": "0.182.0",
    "three-good-godrays": "^0.11.1",
    "three-stdlib": "2.36.1",
    "tslib": "^2.3.0"
  },
  "resolutions": {
    "webpack": "5.105.0"
  },
  "devDependencies": {
    "@analogjs/storybook-angular": "^1.22.0",
    "@analogjs/vite-plugin-angular": "^2.2.3",
    "@angular-devkit/build-angular": "^21.1.4",
    "@angular-eslint/builder": "21.2.0",
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@compodoc/compodoc": "^1.2.1",
    "@eslint/js": "^9.39.2",
    "@storybook/addon-docs": "^9.0.0",
    "@storybook/angular": "^9.0.0",
    "@types/express": "^5.0.1",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/node": "^20.17.19",
    "@types/qrcode": "^1.5.6",
    "@types/three": "0.182.0",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-eslint": "21.2.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.1.0",
    "prettier": "^3.8.1",
    "storybook": "^9.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.50.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.8"
  }
}
